{
  "name": "problem-explorer",
  "displayName": "Problem Explorer",
  "description": "Highlights files and folders with errors and warnings directly in the Explorer",
  "version": "0.5.0-alpha.4",
  "publisher": "Yjaatouri",
  "icon": "icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Yjaatouri/Problem-Explorer-vs-code-extension-.git"
  },
  "bugs": {
    "url": "https://github.com/Yjaatouri/Problem-Explorer-vs-code-extension-/issues"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "keywords": [
    "diagnostics",
    "errors",
    "warnings",
    "explorer",
    "decorations",
    "problems"
  ],
  "engines": {
    "vscode": "^1.90.0"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "problemExplorer.refresh",
        "title": "Refresh Problem Decorations",
        "category": "Problem Explorer"
      },
      {
        "command": "problemExplorer.toggle",
        "title": "Toggle Problem Decorations",
        "category": "Problem Explorer"
      },
      {
        "command": "problemExplorer.scanTypeScript",
        "title": "Scan TypeScript Project (tsc --noEmit)",
        "category": "Problem Explorer"
      },
      {
        "command": "problemExplorer.test",
        "title": "Test Problem Explorer",
        "category": "Problem Explorer"
      },
      {
        "command": "problemExplorer.runExperiment",
        "title": "Run Diagnostics Experiment (openTextDocument)",
        "category": "Problem Explorer"
      },
      {
        "command": "problemExplorer.scanAll",
        "title": "Scan All (TypeScript + ESLint)",
        "category": "Problem Explorer"
      }
    ],
    "keybindings": [
      {
        "command": "problemExplorer.refresh",
        "key": "ctrl+shift+alt+p",
        "mac": "cmd+shift+alt+p",
        "when": "editorFocus"
      }
    ],
    "colors": [
      {
        "id": "problemExplorer.errorForeground",
        "description": "Foreground color for files containing errors",
        "defaults": {
          "dark": "editorError.foreground",
          "light": "editorError.foreground",
          "highContrast": "editorError.foreground",
          "highContrastLight": "editorError.foreground"
        }
      },
      {
        "id": "problemExplorer.warningForeground",
        "description": "Foreground color for files containing warnings",
        "defaults": {
          "dark": "editorWarning.foreground",
          "light": "editorWarning.foreground",
          "highContrast": "editorWarning.foreground",
          "highContrastLight": "editorWarning.foreground"
        }
      },
      {
        "id": "problemExplorer.infoForeground",
        "description": "Foreground color for files containing info diagnostics",
        "defaults": {
          "dark": "editorInfo.foreground",
          "light": "editorInfo.foreground",
          "highContrast": "editorInfo.foreground",
          "highContrastLight": "editorInfo.foreground"
        }
      }
    ],
    "configuration": {
      "title": "Problem Explorer",
      "properties": {
        "problemExplorer.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable problem decorations in the Explorer"
        },
        "problemExplorer.showWarnings": {
          "type": "boolean",
          "default": true,
          "description": "Show warning decorations alongside error decorations"
        },
        "problemExplorer.badgeStyle": {
          "type": "string",
          "default": "letter",
          "enum": [
            "letter",
            "count",
            "dot",
            "none"
          ],
          "enumDescriptions": [
            "Show a single letter badge (E, W, I)",
            "Show the problem count as the badge",
            "Show a small colored dot",
            "Hide the badge text entirely (color only)"
          ],
          "description": "Style of badge shown on files with problems"
        },
        "problemExplorer.ignorePatterns": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "**/node_modules/**",
            "**/.git/**",
            "**/dist/**",
            "**/build/**",
            "**/.next/**",
            "**/target/**",
            "**/__pycache__/**",
            "**/vendor/**",
            "**/.tox/**"
          ],
          "description": "Glob patterns for files and folders to ignore"
        },
        "problemExplorer.errorColor": {
          "type": "string",
          "default": null,
          "description": "Custom CSS color for error badges (overrides theme color). Example: \"#ff0000\"",
          "pattern": "^#[0-9a-fA-F]{6}$|^#[0-9a-fA-F]{8}$|^[a-zA-Z]+$",
          "patternErrorMessage": "Must be a valid hex color (#RRGGBB or #RRGGBBAA) or a CSS color name"
        },
        "problemExplorer.warningColor": {
          "type": "string",
          "default": null,
          "description": "Custom CSS color for warning badges (overrides theme color). Example: \"#ffaa00\"",
          "pattern": "^#[0-9a-fA-F]{6}$|^#[0-9a-fA-F]{8}$|^[a-zA-Z]+$",
          "patternErrorMessage": "Must be a valid hex color (#RRGGBB or #RRGGBBAA) or a CSS color name"
        },
        "problemExplorer.infoColor": {
          "type": "string",
          "default": null,
          "description": "Custom CSS color for info badges (overrides theme color). Example: \"#00aaff\"",
          "pattern": "^#[0-9a-fA-F]{6}$|^[0-9a-fA-F]{8}$|^[a-zA-Z]+$",
          "patternErrorMessage": "Must be a valid hex color (#RRGGBB or #RRGGBBAA) or a CSS color name"
        },
        "problemExplorer.severityOverrides": {
          "type": "object",
          "default": {},
          "description": "Override diagnostic severities per file extension. Keys are file extensions (e.g. \".py\"), values are maps from original severity (Error/Warning/Information/Hint) to target severity. Example: {\".py\": {\"Error\": \"Warning\"}} demotes Python errors to warnings",
          "additionalProperties": {
            "type": "object",
            "description": "Mapping from source severity name to target severity name",
            "properties": {
              "Error": {
                "type": "string",
                "enum": [
                  "Error",
                  "Warning",
                  "Information",
                  "Hint"
                ]
              },
              "Warning": {
                "type": "string",
                "enum": [
                  "Error",
                  "Warning",
                  "Information",
                  "Hint"
                ]
              },
              "Information": {
                "type": "string",
                "enum": [
                  "Error",
                  "Warning",
                  "Information",
                  "Hint"
                ]
              },
              "Hint": {
                "type": "string",
                "enum": [
                  "Error",
                  "Warning",
                  "Information",
                  "Hint"
                ]
              }
            }
          }
        },
        "problemExplorer.autoScan.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable automatic background scanning on file changes"
        },
        "problemExplorer.autoScanDelay": {
          "type": "number",
          "default": 2000,
          "minimum": 500,
          "description": "Delay in milliseconds before triggering an auto-scan after file changes"
        },
        "problemExplorer.typescript.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable TypeScript scanning via tsc --noEmit"
        },
        "problemExplorer.typescript.autoScan": {
          "type": "boolean",
          "default": true,
          "description": "Automatically scan TypeScript projects when files change"
        },
        "problemExplorer.typescript.scanOnStartup": {
          "type": "boolean",
          "default": true,
          "description": "Scan TypeScript projects when the extension activates"
        },
        "problemExplorer.typescript.timeout": {
          "type": "number",
          "default": 120000,
          "minimum": 5000,
          "description": "Timeout in milliseconds for each tsc --noEmit invocation"
        },
        "problemExplorer.typescript.useWorkspaceVersion": {
          "type": "boolean",
          "default": true,
          "description": "Use the workspace's installed TypeScript version instead of VS Code's built-in"
        },
        "problemExplorer.typescript.maxConcurrentScans": {
          "type": "number",
          "default": 1,
          "minimum": 1,
          "maximum": 10,
          "description": "Maximum number of concurrent tsc scans (currently limited to 1)"
        },
        "problemExplorer.eslint.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable ESLint scanning"
        },
        "problemExplorer.eslint.timeout": {
          "type": "number",
          "default": 120000,
          "minimum": 5000,
          "description": "Timeout in milliseconds for each ESLint invocation"
        },
        "problemExplorer.eslint.autoScan": {
          "type": "boolean",
          "default": true,
          "description": "Automatically scan ESLint when JavaScript/TypeScript files change"
        }
      }
    }
  },
  "scripts": {
    "build": "webpack --mode production",
    "watch": "webpack --mode development --watch",
    "lint": "eslint src",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "node ./out/test/runTest.js",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.11.0",
    "@types/sinon": "^22.0.0",
    "@types/vscode": "^1.90.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vscode/test-electron": "^2.4.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "mocha": "^11.0.0",
    "prettier": "^3.3.0",
    "sinon": "^22.0.0",
    "ts-loader": "^9.5.0",
    "typescript": "^5.5.0",
    "@vscode/vsce": "^2.15.0",
    "webpack": "^5.95.0",
    "webpack-cli": "^6.0.0"
  },
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": "limited",
      "description": "Decorations are disabled in untrusted workspaces for security"
    }
  },
  "dependencies": {
    "minimatch": "^10.2.5"
  }
}
